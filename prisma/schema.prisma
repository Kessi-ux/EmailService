generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Email {
  id          String   @id @default(uuid())
  to          String
  from        String
  subject     String
  body        String
  status      EmailStatus @default(PENDING)
  sentAt      DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Template {
  id        String   @id @default(uuid())
  name      String   @unique
  subject   String
  body      String
  variables Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Queue {
  id          String   @id @default(uuid())
  emailId     String
  status      QueueStatus @default(PENDING)
  retries     Int      @default(0)
  scheduledAt DateTime?
  lastError   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Unsubscribe {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  isBounced   Boolean  @default(false)
  isComplaint Boolean  @default(false)
  createdAt DateTime @default(now())
}

model EmailEvent {
  id        String   @id @default(cuid())
  email     String
  messageId String?
  type      EmailEventType
  createdAt DateTime @default(now())
  metadata  Json?
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
}

enum QueueStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

enum EmailEventType {
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  COMPLAINT
}
